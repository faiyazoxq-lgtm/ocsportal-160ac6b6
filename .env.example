# OCS Work Order Platform — environment template
# Real values are managed by Lovable Cloud and injected automatically.
# This file documents the variables the app expects.

# --- Public (browser-safe, injected by Vite at build time) ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-anon-key>
VITE_SUPABASE_PROJECT_ID=<project-ref>

# --- Server runtime (TanStack server functions / server routes only) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<publishable-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # NEVER expose to the client

# --- Google Sheets planner sync (server-only) ---
GOOGLE_SERVICE_ACCOUNT_JSON=<service-account-json-string>
PLANNER_SPREADSHEET_ID=<google-sheet-id>
PLANNER_SHEET_NAME=<tab-name>

# --- Telegram notification bridge (managed by Lovable connector) ---
TELEGRAM_API_KEY=<telegram-bot-token>

# --- Lovable AI Gateway (optional, for AI features) ---
LOVABLE_API_KEY=<lovable-api-key>